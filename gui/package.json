{
  "name": "fulldome-preview-converter",
  "version": "0.2.0",
  "description": "Fulldome fisheye to 16:9 preview converter for Dome Fest West",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "vite build",
    "dev": "concurrently \"vite --port 5274\" \"wait-on http://localhost:5274 && electron .\"",
    "fetch-ffmpeg": "node ../scripts/fetch-ffmpeg.js",
    "build-convert": "node ../scripts/build-convert-binary.js",
    "test:matrix": "node ../scripts/dev-test.js matrix",
    "test:launch": "node ../scripts/dev-test.js launch",
    "test:stop": "node ../scripts/dev-test.js stop",
    "make": "npm run build && electron-builder",
    "make:mac": "npm run build && electron-builder --mac",
    "make:win": "npm run build && electron-builder --win",
    "make:linux": "npm run build && electron-builder --linux"
  },
  "keywords": ["fulldome", "ffmpeg", "video", "converter"],
  "author": "Dome Fest West",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "build": {
    "appId": "com.domefestwest.fulldome-converter",
    "productName": "Fulldome Preview Converter",
    "directories": {
      "buildResources": "build",
      "output": "../release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../convert.py",
        "to": "convert.py"
      },
      {
        "from": "../bin/",
        "to": "bin/",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "target": [{"target": "dmg", "arch": ["arm64", "x64"]}],
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Fulldome Preview Converter ${version}",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [{"target": "nsis", "arch": ["x64"]}]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [{"target": "AppImage", "arch": ["x64"]}],
      "category": "AudioVideo",
      "synopsis": "Convert fulldome fisheye media to 16:9 preview with PiP overlay",
      "description": "Fulldome Preview Converter turns 1:1 dome-master video and stills into 16:9, 9:16, or 1:1 preview deliverables for marketing and submissions. Built by Dome Fest West."
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
